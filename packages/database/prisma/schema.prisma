// If you sit on the order book then you are the maker, if not, you are the taker.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  schemas  = ["public", "_timescaledb_internal"]
}

datasource db {
  provider = "postgresql"
}

enum MarketType {
  PERP
  SPOT
}

enum TradeSide {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum LiquidType {
  MAKER
  TAKER
}

enum OrderStatus {
  OPEN
  FILLED
  PARTIAL
  CANCELLED
}

model User {
  id       String @id @default(uuid())
  name     String
  username String
  password String
  // fiatBalance       Float ---> Would be stored in memory
  // lockedFiat        Float ---> Would be stored in memory

  userAssetBalances userAssetBalance[]
  orderHistories    OrderHistory[]
  // Point these back to the respective named relations in Fills
  makerFills        Fills[]            @relation("MakerFills")
  takerFills        Fills[]            @relation("TakerFills")
}

model Asset {
  id                String             @id @default(uuid())
  name              String
  symbol            String
  logo              String
  userAssetBalances userAssetBalance[]
  baseMarkets       Market[]           @relation("BaseAsset")
  quoteMarkets      Market[]           @relation("QuoteAsset")
}

model Market {
  id             String         @id @default(uuid())
  name           String
  baseAssetId    String
  quoteAssetId   String
  baseAsset      Asset?         @relation("BaseAsset", fields: [baseAssetId], references: [id])
  quoteAsset     Asset?         @relation("QuoteAsset", fields: [quoteAssetId], references: [id])
  orderHistories OrderHistory[]
  fills          Fills[]
}

model userAssetBalance {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id])
  asset    Asset  @relation(fields: [assetsId], references: [id])
  amount   Float
  userId   String
  assetsId String
}

// The intended orders of the user
model OrderHistory {
  id        String      @id @default(uuid()) // Reverted back to standalone standard PK
  amount    Float
  price     Float
  type      OrderType
  side      TradeSide
  userId    String
  marketId  String
  status    OrderStatus
  timestamp DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])
  market    Market      @relation(fields: [marketId], references: [id])
}

model Fills {
  id                     String     @default(uuid())
  makerUser              User       @relation("MakerFills", fields: [makerUserId], references: [id])
  takerUser              User       @relation("TakerFills", fields: [takerUserId], references: [id])
  market                 Market     @relation(fields: [marketId], references: [id])
  amount                 Float
  price                  Float
  type                   OrderType
  marketType             MarketType
  side                   TradeSide
  liquidType             LiquidType
  makerUserId            String
  takerUserId            String
  marketId               String
  // Kept as plain scalar fields for application-level tracking
  // without database-level Foreign Key constraints
  originalOrderId        String
  originalOrderTimestamp DateTime

  fee       String // Tip: Float is risky for financial balances, consider Decimal/String for production
  timestamp DateTime @default(now())

  // Required by TimescaleDB: The time column must be in the Primary Key
  @@id([id, timestamp])
}
